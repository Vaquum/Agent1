AGENT1_DOCKER_MODE=dev
PORT=8000

DATABASE_URL=postgresql://user:password@host:5432/postgres

GITHUB_API_URL=https://api.github.com
GITHUB_USER=your-github-bot-user
# classic PAT scope for private repos: repo
GITHUB_TOKEN=
GITHUB_HTTP_TIMEOUT_SECONDS=30

OPENAI_API_KEY=sk-replace-with-openai-api-key
CODEX_CLI_COMMAND=codex
CODEX_CLI_TIMEOUT_SECONDS=900

RUNTIME_INSTANCE_ID=
RUNTIME_ENVIRONMENT=
RUNTIME_MODE_OVERRIDE=

SENTRY_PYTHON_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=0.1.0
SENTRY_TRACES_SAMPLE_RATE=0.2

OTEL_SERVICE_NAME=agent1-backend
OTEL_TRACES_SAMPLER=always_on
OTEL_PROPAGATORS=tracecontext,baggage
