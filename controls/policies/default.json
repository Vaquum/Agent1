{
  "version": "0.1.0",
  "repo_scope": [
    "Vaquum/Agent1"
  ],
  "agent_actor": "zero-bang",
  "ignored_actors": [],
  "ignored_actor_suffixes": [
    "[bot]"
  ],
  "deny_git_commands": [
    "git push --force",
    "git push --force-with-lease",
    "git reset --hard",
    "git clean -fdx"
  ],
  "rules": [
    {
      "id": "no-destructive-git",
      "description": "Block destructive git operations.",
      "allow": false
    }
  ]
}
